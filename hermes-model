#!/usr/bin/env bash
# hermes-model — Interactive Hermes model/fallback/API key manager
# Usage: hermes-model [--dry-run]

set -uo pipefail

CONFIG="$HOME/.hermes/config.yaml"
ENV_FILE="$HOME/.hermes/.env"
HERMES_BIN="$HOME/.local/bin/hermes"

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

# ── Model catalog ─────────────────────────────────────────────────────────────
# Format per entry: "provider_label|model_id|description|provider|is_free"
# No pipe characters inside any individual field.
MODEL_CATALOG=(
  "openrouter|deepseek/deepseek-v4-flash|[recommended]|openrouter|0"
  "openrouter|deepseek/deepseek-chat||openrouter|0"
  "deepseek|deepseek-v4-flash|[direct API]|deepseek|0"
  "deepseek|deepseek-chat|[direct API]|deepseek|0"
  "openrouter|google/gemma-4-31b-it:free|[262K ctx, Vision+Tools]|openrouter|1"
  "openrouter|nvidia/nemotron-3-super-120b-a12b:free|[1M ctx, Tools]|openrouter|1"
  "openrouter|openai/gpt-oss-120b:free|[131K ctx, Tools]|openrouter|1"
  "openrouter|qwen/qwen3-coder:free|[1M ctx, best coding]|openrouter|1"
  "openrouter|openai/gpt-oss-20b:free|[131K ctx, Tools]|openrouter|1"
  "openrouter|z-ai/glm-4.5-air:free|[131K ctx, Tools]|openrouter|1"
  "openrouter|qwen/qwen3-next-80b-a3b-instruct:free|[262K ctx]|openrouter|1"
  "openrouter|meta-llama/llama-3.3-70b-instruct:free|[131K ctx]|openrouter|1"
  "openrouter|moonshotai/kimi-k2.6:free|[262K ctx, Vision]|openrouter|1"
  "openrouter|nvidia/nemotron-3-ultra-550b-a55b:free|[1M ctx]|openrouter|1"
  "openrouter|nousresearch/hermes-3-llama-3.1-405b:free|[131K ctx]|openrouter|1"
  "openrouter|openrouter/owl-alpha|[1M ctx, OpenRouter native]|openrouter|1"
  "custom|custom||custom|0"
)

# ── Helpers ───────────────────────────────────────────────────────────────────
die() { echo -e "${RED}ERROR: $*${RESET}" >&2; exit 1; }

require_config() {
  [[ -f "$CONFIG" ]] || die "Config not found: $CONFIG"
}

press_enter() {
  echo ""
  read -rp "  Tekan Enter untuk kembali ke menu..." _
}

yaml_get() {
  local key="$1"
  python3 - "$CONFIG" "$key" <<'PYEOF'
import sys
path = sys.argv[1]
key  = sys.argv[2]
with open(path) as f:
    content = f.read()
leaf = key.split('.')[-1]
for line in content.splitlines():
    stripped = line.strip()
    if stripped.startswith(leaf + ':'):
        val = stripped[len(leaf)+1:].strip().strip("'\"")
        print(val)
        sys.exit(0)
print('')
PYEOF
}

yaml_get_fallbacks() {
  python3 - "$CONFIG" <<'PYEOF'
import sys
with open(sys.argv[1]) as f:
    content = f.read()
in_block = False
provider = model = ''
entries = []
for line in content.splitlines():
    stripped = line.strip()
    if stripped in ('fallback_providers:', 'fallback_providers: []'):
        in_block = True
        continue
    if in_block:
        if stripped.startswith('- provider:'):
            if provider and model:
                entries.append(f"{provider}|{model}")
            provider = stripped.split(':', 1)[1].strip().strip("'\"")
            model = ''
        elif stripped.startswith('model:'):
            model = stripped.split(':', 1)[1].strip().strip("'\"")
        elif stripped and not stripped.startswith('#') and line[0] not in (' ', '\t'):
            break
if provider and model:
    entries.append(f"{provider}|{model}")
print('\n'.join(entries))
PYEOF
}

get_env_key() {
  local var="$1"
  local val="${!var:-}"
  if [[ -z "$val" && -f "$ENV_FILE" ]]; then
    val=$(grep -E "^${var}=" "$ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d "'\"\n" || true)
  fi
  echo "$val"
}

mask_key() {
  local key="$1"
  if [[ -z "$key" ]]; then echo "(not set)"; return; fi
  local len=${#key}
  if (( len <= 8 )); then echo "****"; return; fi
  echo "${key:0:6}****${key: -4}"
}

# ── Config display ─────────────────────────────────────────────────────────────
show_config() {
  require_config
  local primary_provider primary_model
  primary_provider=$(yaml_get "provider")
  primary_model=$(yaml_get "default")

  echo ""
  echo -e "${BOLD}${CYAN}══════════════════════════════════════════${RESET}"
  echo -e "${BOLD}  Hermes Current Configuration${RESET}"
  echo -e "${BOLD}${CYAN}══════════════════════════════════════════${RESET}"
  echo ""
  echo -e "  ${BOLD}PRIMARY MODEL${RESET}"
  echo -e "    Provider : ${GREEN}${primary_provider:-<unset>}${RESET}"
  echo -e "    Model    : ${GREEN}${primary_model:-<unset>}${RESET}"
  echo ""
  echo -e "  ${BOLD}FALLBACK PROVIDERS${RESET}"
  local fallbacks
  fallbacks=$(yaml_get_fallbacks)
  if [[ -z "$fallbacks" ]]; then
    echo -e "    ${YELLOW}(none configured)${RESET}"
  else
    local i=1
    while IFS='|' read -r fp fm; do
      echo -e "    ${i}. ${GREEN}${fp}${RESET} | ${fm}"
      (( i++ ))
    done <<< "$fallbacks"
  fi
  echo ""
  echo -e "  ${BOLD}API KEYS${RESET}"
  echo -e "    OPENROUTER_API_KEY : $(mask_key "$(get_env_key OPENROUTER_API_KEY)")"
  echo -e "    DEEPSEEK_API_KEY   : $(mask_key "$(get_env_key DEEPSEEK_API_KEY)")"
  echo ""
}

# ── YAML writers ───────────────────────────────────────────────────────────────
write_primary() {
  local new_provider="$1" new_model="$2"
  python3 - "$CONFIG" "$new_provider" "$new_model" <<'PYEOF'
import sys
config_path  = sys.argv[1]
new_provider = sys.argv[2]
new_model    = sys.argv[3]

with open(config_path) as f:
    lines = f.readlines()

out = []
in_model_block = False
provider_done = model_done = False

for line in lines:
    stripped = line.strip()
    if stripped == 'model:':
        in_model_block = True
        out.append(line)
        continue
    if in_model_block:
        if stripped.startswith('provider:') and not provider_done:
            indent = len(line) - len(line.lstrip())
            out.append(' ' * indent + f'provider: {new_provider}\n')
            provider_done = True
            continue
        if stripped.startswith('default:') and not model_done:
            indent = len(line) - len(line.lstrip())
            out.append(' ' * indent + f'default: {new_model}\n')
            model_done = True
            continue
        if stripped and not stripped.startswith('#') and line[0] not in (' ', '\t'):
            in_model_block = False
    out.append(line)

with open(config_path, 'w') as f:
    f.writelines(out)
print('ok')
PYEOF
}

write_fallbacks() {
  local fallback_data="$1"
  python3 - "$CONFIG" "$fallback_data" <<'PYEOF'
import sys
config_path   = sys.argv[1]
fallback_data = sys.argv[2]

new_block_lines = ['fallback_providers:\n']
if fallback_data.strip():
    for entry in fallback_data.strip().split('\n'):
        if '|' in entry:
            prov, mod = entry.split('|', 1)
            new_block_lines.append(f'- provider: {prov.strip()}\n')
            new_block_lines.append(f'  model: {mod.strip()}\n')
else:
    new_block_lines = ['fallback_providers: []\n']

with open(config_path) as f:
    lines = f.readlines()

out = []
i = 0
while i < len(lines):
    line = lines[i]
    if line.strip() in ('fallback_providers:', 'fallback_providers: []'):
        out.extend(new_block_lines)
        i += 1
        while i < len(lines):
            l = lines[i]
            s = l.strip()
            if s.startswith('- provider:') or s.startswith('model:') or (l[0] in (' ', '\t') and s):
                i += 1
                continue
            break
        continue
    out.append(line)
    i += 1

with open(config_path, 'w') as f:
    f.writelines(out)
print('ok')
PYEOF
}

# ── Model picker UI ────────────────────────────────────────────────────────────
# Sets PICKED_PROVIDER and PICKED_MODEL on success.
# Returns 1 if user chose 0 (back) or invalid input.
pick_model() {
  local purpose="${1:-select}"
  echo ""
  echo -e "${BOLD}  === PAID (pakai API key/credit) ===${RESET}"
  local i=1
  for (( idx=0; idx<4; idx++ )); do
    IFS='|' read -r m_prov m_model m_desc m_provider m_free <<< "${MODEL_CATALOG[$idx]}"
    printf "  %2d.  %-12s| %-45s %s\n" "$i" "$m_prov" "$m_model" "$m_desc"
    (( i++ ))
  done

  echo ""
  echo -e "${BOLD}  === GRATIS via OpenRouter (:free) ===${RESET}"
  for (( idx=4; idx<${#MODEL_CATALOG[@]}; idx++ )); do
    IFS='|' read -r m_prov m_model m_desc m_provider m_free <<< "${MODEL_CATALOG[$idx]}"
    if [[ "$m_provider" == "custom" ]]; then
      printf "  %2d.  %s\n" "$i" "Custom - input provider and model manually"
    else
      printf "  %2d.  %-12s| %-45s %s\n" "$i" "$m_prov" "$m_model" "$m_desc"
    fi
    (( i++ ))
  done

  echo ""
  echo "   0.  Kembali / Back"
  echo ""
  local total=${#MODEL_CATALOG[@]}
  read -rp "  Pilih nomor model untuk ${purpose} [0-${total}]: " choice
  choice=$(echo "$choice" | tr -d '[:space:]')

  if [[ "$choice" == "0" ]]; then
    echo -e "${YELLOW}  Kembali ke menu sebelumnya.${RESET}"; return 1  # caller must use || return 0
  fi

  if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > total )); then
    echo -e "${RED}  Pilihan tidak valid.${RESET}"; return 1
  fi

  local catalog_idx=$(( choice - 1 ))
  IFS='|' read -r m_prov m_model m_desc sel_provider m_free <<< "${MODEL_CATALOG[$catalog_idx]}"
  local sel_model="$m_model"

  if [[ "$sel_provider" == "custom" ]]; then
    read -rp "  Masukkan provider (misal: openrouter, deepseek, openai): " sel_provider
    read -rp "  Masukkan model ID: " sel_model
    m_free=0
  fi

  if [[ "$m_free" == "1" ]]; then
    echo ""
    echo -e "${YELLOW}  ⚠️  Model gratis punya rate limit 200 req/day - lanjut? [y/N]${RESET}"
    read -rp "  > " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
      echo -e "${YELLOW}  Dibatalkan.${RESET}"; return 1  # caller uses || return 0 / || continue
    fi
  fi

  PICKED_PROVIDER="$sel_provider"
  PICKED_MODEL="$sel_model"
  return 0
}

# ── Gateway restart ────────────────────────────────────────────────────────────
restart_gateway() {
  echo ""
  echo -e "${CYAN}  Merestart Hermes gateway...${RESET}"
  if [[ -x "$HERMES_BIN" ]]; then
    if "$HERMES_BIN" gateway restart 2>&1; then
      echo -e "${GREEN}  ✓ Hermes restarted with new config.${RESET}"
    else
      echo -e "${YELLOW}  ⚠ Gateway restart returned non-zero (mungkin sudah jalan ulang).${RESET}"
      echo -e "${GREEN}  ✓ Config tersimpan — Hermes akan pakai model baru di sesi berikutnya.${RESET}"
    fi
  else
    echo -e "${YELLOW}  hermes binary tidak ditemukan di $HERMES_BIN — skip restart.${RESET}"
    echo -e "${GREEN}  ✓ Config tersimpan — restart Hermes secara manual jika perlu.${RESET}"
  fi
}

# ── Menu: Primary ──────────────────────────────────────────────────────────────
menu_primary() {
  echo ""
  echo -e "${BOLD}── Change PRIMARY Model ──────────────────────${RESET}"
  PICKED_PROVIDER="" PICKED_MODEL=""
  pick_model "primary" || return 0   # user chose 0 → back to main menu
  echo ""
  echo -e "  Akan set primary → ${GREEN}${PICKED_PROVIDER}${RESET} | ${GREEN}${PICKED_MODEL}${RESET}"
  read -rp "  Konfirmasi? [Y/n]: " ok
  if [[ "$ok" =~ ^[Nn]$ ]]; then echo "  Dibatalkan."; press_enter; return 0; fi
  write_primary "$PICKED_PROVIDER" "$PICKED_MODEL"
  echo -e "${GREEN}  ✓ Primary model diupdate: ${PICKED_PROVIDER} | ${PICKED_MODEL}${RESET}"
  restart_gateway
  press_enter
  return 0
}

# ── Menu: Fallbacks ────────────────────────────────────────────────────────────
menu_fallbacks() {
  while true; do
    echo ""
    echo -e "${BOLD}── Manage FALLBACK Models ────────────────────${RESET}"
    local fallbacks
    fallbacks=$(yaml_get_fallbacks)
    local fb_arr=()
    if [[ -z "$fallbacks" ]]; then
      echo -e "  ${YELLOW}(tidak ada fallback terkonfigurasi)${RESET}"
    else
      local i=1
      while IFS='|' read -r fp fm; do
        echo -e "  ${i}. ${GREEN}${fp}${RESET} | ${fm}"
        fb_arr+=("${fp}|${fm}")
        (( i++ ))
      done <<< "$fallbacks"
    fi
    echo ""
    echo "  a) Add fallback"
    echo "  r) Remove by number"
    echo "  s) Swap/reorder two entries"
    echo "  c) Clear all fallbacks"
    echo "  0) Back to main menu"
    echo ""
    read -rp "  Pilihan: " sub
    case "$sub" in
      a|A)
        PICKED_PROVIDER="" PICKED_MODEL=""
        pick_model "fallback" || { continue; }   # 0/invalid → redraw fallback menu
        fb_arr+=("${PICKED_PROVIDER}|${PICKED_MODEL}")
        write_fallbacks "$(printf '%s\n' "${fb_arr[@]}")"
        echo -e "${GREEN}  ✓ Fallback ditambahkan: ${PICKED_PROVIDER} | ${PICKED_MODEL}${RESET}"
        restart_gateway
        press_enter
        ;;
      r|R)
        if [[ ${#fb_arr[@]} -eq 0 ]]; then echo "  Tidak ada fallback."; continue; fi
        read -rp "  Hapus nomor berapa? [1-${#fb_arr[@]}] (0=batal): " num
        [[ "$num" == "0" ]] && continue
        if ! [[ "$num" =~ ^[0-9]+$ ]] || (( num < 1 || num > ${#fb_arr[@]} )); then
          echo -e "${RED}  Nomor tidak valid.${RESET}"; continue
        fi
        local removed="${fb_arr[$(( num-1 ))]}"
        fb_arr=( "${fb_arr[@]:0:$(( num-1 ))}" "${fb_arr[@]:$num}" )
        write_fallbacks "$(printf '%s\n' "${fb_arr[@]}")"
        echo -e "${GREEN}  ✓ Fallback #${num} dihapus: ${removed/|/ | }${RESET}"
        restart_gateway
        press_enter
        ;;
      s|S)
        if [[ ${#fb_arr[@]} -lt 2 ]]; then echo "  Butuh minimal 2 fallback untuk swap."; continue; fi
        read -rp "  Swap posisi A [1-${#fb_arr[@]}] (0=batal): " posA
        [[ "$posA" == "0" ]] && continue
        read -rp "  Swap posisi B [1-${#fb_arr[@]}] (0=batal): " posB
        [[ "$posB" == "0" ]] && continue
        if ! [[ "$posA" =~ ^[0-9]+$ && "$posB" =~ ^[0-9]+$ ]] \
           || (( posA < 1 || posA > ${#fb_arr[@]} || posB < 1 || posB > ${#fb_arr[@]} )); then
          echo -e "${RED}  Posisi tidak valid.${RESET}"; continue
        fi
        local tmp="${fb_arr[$(( posA-1 ))]}"
        fb_arr[$(( posA-1 ))]="${fb_arr[$(( posB-1 ))]}"
        fb_arr[$(( posB-1 ))]="$tmp"
        write_fallbacks "$(printf '%s\n' "${fb_arr[@]}")"
        echo -e "${GREEN}  ✓ Posisi ${posA} ↔ ${posB} ditukar.${RESET}"
        restart_gateway
        press_enter
        ;;
      c|C)
        read -rp "  Hapus SEMUA fallback? [y/N]: " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
          write_fallbacks ""
          echo -e "${GREEN}  ✓ Semua fallback dihapus.${RESET}"
          restart_gateway
          press_enter
        fi
        ;;
      0) return ;;
      *) echo -e "${RED}  Pilihan tidak dikenali.${RESET}" ;;
    esac
  done
}

# ── Menu: API Keys ─────────────────────────────────────────────────────────────
write_env_key() {
  local var="$1" val="$2"
  touch "$ENV_FILE"
  local tmp
  tmp=$(grep -v "^${var}=" "$ENV_FILE" 2>/dev/null || true)
  printf '%s\n' "$tmp" | grep -v '^$' > "$ENV_FILE" || true
  echo "${var}=${val}" >> "$ENV_FILE"
}

menu_apikeys() {
  while true; do
    echo ""
    echo -e "${BOLD}── Manage API Keys ───────────────────────────${RESET}"
    echo -e "  OPENROUTER_API_KEY : $(mask_key "$(get_env_key OPENROUTER_API_KEY)")"
    echo -e "  DEEPSEEK_API_KEY   : $(mask_key "$(get_env_key DEEPSEEK_API_KEY)")"
    if [[ -f "$ENV_FILE" ]]; then
      while IFS='=' read -r k v; do
        [[ "$k" == "OPENROUTER_API_KEY" || "$k" == "DEEPSEEK_API_KEY" ]] && continue
        [[ -z "$k" || "$k" =~ ^# ]] && continue
        echo -e "  ${k} : $(mask_key "$v")"
      done < "$ENV_FILE"
    fi
    echo ""
    echo "  1) Update OPENROUTER_API_KEY"
    echo "  2) Update DEEPSEEK_API_KEY"
    echo "  3) Add/update custom provider key"
    echo "  0) Back to main menu"
    echo ""
    read -rp "  Pilihan: " sub
    case "$sub" in
      1)
        read -rsp "  Masukkan OPENROUTER_API_KEY (input tersembunyi): " new_key; echo
        if [[ -n "$new_key" ]]; then
          write_env_key "OPENROUTER_API_KEY" "$new_key"
          echo -e "${GREEN}  ✓ OPENROUTER_API_KEY disimpan ke ${ENV_FILE}${RESET}"
          press_enter
        fi
        ;;
      2)
        read -rsp "  Masukkan DEEPSEEK_API_KEY (input tersembunyi): " new_key; echo
        if [[ -n "$new_key" ]]; then
          write_env_key "DEEPSEEK_API_KEY" "$new_key"
          echo -e "${GREEN}  ✓ DEEPSEEK_API_KEY disimpan ke ${ENV_FILE}${RESET}"
          press_enter
        fi
        ;;
      3)
        read -rp "  Nama variable (misal: ANTHROPIC_API_KEY): " var_name
        var_name=$(echo "$var_name" | tr '[:lower:]' '[:upper:]' | tr ' ' '_')
        read -rsp "  Masukkan nilai key (input tersembunyi): " new_key; echo
        if [[ -n "$var_name" && -n "$new_key" ]]; then
          write_env_key "$var_name" "$new_key"
          echo -e "${GREEN}  ✓ ${var_name} disimpan ke ${ENV_FILE}${RESET}"
          press_enter
        fi
        ;;
      0) return ;;
      *) echo -e "${RED}  Pilihan tidak dikenali.${RESET}" ;;
    esac
  done
}

# ── Dry-run ────────────────────────────────────────────────────────────────────
