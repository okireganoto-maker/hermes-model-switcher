    IFS='|' read -r m_prov m_model m_desc m_provider m_free <<< "${MODEL_CATALOG[$idx]}"
    printf "  %2d.  %-12s| %-45s %s\n" "$local_i" "$m_prov" "$m_model" "$m_desc"
    (( local_i++ ))
